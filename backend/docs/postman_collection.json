    {
      "name": "8. AI Training Logs",
      "item": [
        {
          "name": "Create ai-model untuk training log",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/ai-models",
            "body": { "mode": "raw", "raw": "{\n  \"version_name\": \"postman_training_target\",\n  \"architecture_type\": \"VAE\"\n}" }
          },
          "event": [
            {
              "listen": "test",
              "script": { "type": "text/javascript", "exec": ["pm.collectionVariables.set('modelId', pm.response.json().id);"] }
            }
          ]
        },
        {
          "name": "List training logs",
          "request": { "method": "GET", "url": "{{baseUrl}}/api/ai-training-logs?modelId={{modelId}}" },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.test('Status 200', () => pm.response.to.have.status(200));"] } }]
        },
        {
