              "raw": "{\n  \"case_id\": \"{{caseId}}\",\n  \"input_cctv_url\": \"https://example.com/cctv1.jpg\",\n  \"output_ai_url\": \"https://example.com/output1.jpg\",\n  \"ssim_score\": 0.91,\n  \"psnr_score\": 28.4,\n  \"processing_time_ms\": 350\n}"
