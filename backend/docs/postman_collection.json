              "raw": "{\n  \"model_id\": \"{{modelId}}\",\n  \"epoch_number\": 1,\n  \"generator_loss\": 0.53,\n  \"discriminator_loss\": 0.48,\n  \"duration_seconds\": 12.5\n}"
            }
          },
          "event": [
            {
              "listen": "test",
