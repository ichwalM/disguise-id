        },
        {
          "name": "Create user (Operator, role_id=2)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/users",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"postman.operator@disguise.id\",\n  \"password\": \"OperatorPass123!\",\n  \"full_name\": \"Postman Operator\",\n  \"role_id\": 2\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "pm.collectionVariables.set('newUserId', pm.response.json().id);",
                  "pm.collectionVariables.set('operatorUserId', pm.response.json().id);"
                ]
              }
            }
          ]
        },
        {
          "name": "Create user - email duplikat (expect 409)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/users",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"postman.operator@disguise.id\",\n  \"password\": \"Lain123!\"\n}"
            }
          },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.test('Status 409', () => pm.response.to.have.status(409));"] } }]
        },
        {
          "name": "Get user by id",
          "request": { "method": "GET", "url": "{{baseUrl}}/api/users/{{newUserId}}" },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.test('Status 200', () => pm.response.to.have.status(200));"] } }]
        },
        {
          "name": "Update user (ganti full_name)",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/users/{{newUserId}}",
            "body": { "mode": "raw", "raw": "{\n  \"full_name\": \"Postman Operator (updated)\"\n}" }
          },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.test('Status 200', () => pm.response.to.have.status(200));"] } }]
        }
      ]
    },
