{
  "info": {
    "name": "DISGUISE-ID API",
    "description": "Koleksi Postman untuk backend disguise-api. Jalankan folder secara berurutan dari atas ke bawah — request Login menyimpan token secara otomatis ke variable collection, dan request Create menyimpan id hasil create ke variable yang dipakai request berikutnya (Get/Update/Delete).",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:4000" },
    { "key": "token", "value": "" },
    { "key": "operatorToken", "value": "" },
    { "key": "roleId", "value": "" },
    { "key": "newUserId", "value": "" },
    { "key": "operatorUserId", "value": "" },
    { "key": "timelineId", "value": "" },
    { "key": "datasetId", "value": "" },
    { "key": "modelId", "value": "" },
    { "key": "model2Id", "value": "" },
    { "key": "trainingLogId", "value": "" },
    { "key": "caseId", "value": "" },
    { "key": "resultId", "value": "" }
  ],
  "item": [
    {
      "name": "1. Auth",
      "item": [
        {
          "name": "Login (Super Admin)",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"ichwal.admin@disguise.id\",\n  \"password\": \"AdminRahasia123!\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const json = pm.response.json();",
                  "pm.test('Ada token', () => pm.expect(json.token).to.be.a('string'));",
                  "pm.collectionVariables.set('token', json.token);"
                ]
              }
            }
          ]
        },
        {
          "name": "Login - salah password (expect 401)",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"ichwal.admin@disguise.id\",\n  \"password\": \"salah\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": { "type": "text/javascript", "exec": ["pm.test('Status 401', () => pm.response.to.have.status(401));"] }
            }
          ]
        },
        {
          "name": "Get profil sendiri (/me)",
          "request": { "method": "GET", "url": "{{baseUrl}}/api/auth/me" },
          "event": [
            {
              "listen": "test",
              "script": { "type": "text/javascript", "exec": ["pm.test('Status 200', () => pm.response.to.have.status(200));"] }
            }
          ]
        },
        {
          "name": "/me tanpa token (expect 401)",
          "request": { "auth": { "type": "noauth" }, "method": "GET", "url": "{{baseUrl}}/api/auth/me" },
          "event": [
            {
              "listen": "test",
              "script": { "type": "text/javascript", "exec": ["pm.test('Status 401', () => pm.response.to.have.status(401));"] }
            }
          ]
        },
        {
          "name": "Logout",
          "request": { "method": "POST", "url": "{{baseUrl}}/api/auth/logout" },
          "event": [
            {
              "listen": "test",
              "script": { "type": "text/javascript", "exec": ["pm.test('Status 200', () => pm.response.to.have.status(200));"] }
            }
          ]
        }
      ]
    },
    {
      "name": "2. Dashboard",
      "item": [
        {
          "name": "Get stats",
          "request": { "method": "GET", "url": "{{baseUrl}}/api/dashboard/stats" },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const json = pm.response.json();",
                  "pm.test('Ada totalUsers & recentActivities', () => { pm.expect(json).to.have.property('totalUsers'); pm.expect(json).to.have.property('recentActivities'); });"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "3. Roles (Super Admin only)",
      "item": [
        {
          "name": "List roles",
          "request": { "method": "GET", "url": "{{baseUrl}}/api/roles?limit=20&offset=0" },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.test('Status 200', () => pm.response.to.have.status(200));"] } }]
        },
        {
          "name": "Create role",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/roles",
            "body": { "mode": "raw", "raw": "{\n  \"role_name\": \"Postman Test Role\"\n}" }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "pm.collectionVariables.set('roleId', pm.response.json().id);"
                ]
              }
            }
          ]
        },
        {
          "name": "Get role by id",
          "request": { "method": "GET", "url": "{{baseUrl}}/api/roles/{{roleId}}" },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.test('Status 200', () => pm.response.to.have.status(200));"] } }]
        },
        {
          "name": "Update role",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/roles/{{roleId}}",
            "body": { "mode": "raw", "raw": "{\n  \"role_name\": \"Postman Test Role (updated)\"\n}" }
          },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.test('Status 200', () => pm.response.to.have.status(200));"] } }]
        },
        {
          "name": "Get role tidak ditemukan (expect 404)",
          "request": { "method": "GET", "url": "{{baseUrl}}/api/roles/999999" },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.test('Status 404', () => pm.response.to.have.status(404));"] } }]
        },
        {
          "name": "Delete role",
          "request": { "method": "DELETE", "url": "{{baseUrl}}/api/roles/{{roleId}}" },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.test('Status 200', () => pm.response.to.have.status(200));"] } }]
        }
      ]
    },
