    {
      "name": "7. AI Models",
      "item": [
        {
          "name": "List ai-models",
          "request": { "method": "GET", "url": "{{baseUrl}}/api/ai-models?limit=20&offset=0" },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.test('Status 200', () => pm.response.to.have.status(200));"] } }]
        },
        {
          "name": "Create ai-model #1",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/ai-models",
            "body": { "mode": "raw", "raw": "{\n  \"version_name\": \"postman_vae_v1\",\n  \"architecture_type\": \"VAE\",\n  \"hyperparameters\": { \"lr\": 0.001 }\n}" }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "const json = pm.response.json();",
                  "pm.test('is_active default false', () => pm.expect(Number(json.is_active)).to.eql(0));",
                  "pm.collectionVariables.set('modelId', json.id);"
                ]
              }
            }
          ]
        },
        {
          "name": "Create ai-model #2",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/ai-models",
            "body": { "mode": "raw", "raw": "{\n  \"version_name\": \"postman_vae_v2\",\n  \"architecture_type\": \"VAE\"\n}" }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "pm.collectionVariables.set('model2Id', pm.response.json().id);"
                ]
              }
            }
          ]
        },
        {
          "name": "Activate ai-model #1",
          "request": { "method": "PATCH", "url": "{{baseUrl}}/api/ai-models/{{modelId}}/activate" },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('is_active true', () => pm.expect(Number(pm.response.json().is_active)).to.eql(1));"
                ]
              }
            }
          ]
        },
        {
          "name": "Activate ai-model #2 (otomatis nonaktifkan #1)",
          "request": { "method": "PATCH", "url": "{{baseUrl}}/api/ai-models/{{model2Id}}/activate" },
          "event": [
            {
              "listen": "test",
              "script": { "type": "text/javascript", "exec": ["pm.test('Status 200', () => pm.response.to.have.status(200));"] }
            }
          ]
        },
        {
          "name": "Get ai-model #1 (expect is_active=0, sudah dinonaktifkan)",
          "request": { "method": "GET", "url": "{{baseUrl}}/api/ai-models/{{modelId}}" },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": ["pm.test('is_active false', () => pm.expect(Number(pm.response.json().is_active)).to.eql(0));"]
              }
            }
          ]
        },
        {
          "name": "Activate id tidak ada (expect 404)",
          "request": { "method": "PATCH", "url": "{{baseUrl}}/api/ai-models/does-not-exist/activate" },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.test('Status 404', () => pm.response.to.have.status(404));"] } }]
        },
        {
          "name": "Delete ai-model #1",
          "request": { "method": "DELETE", "url": "{{baseUrl}}/api/ai-models/{{modelId}}" },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.test('Status 200', () => pm.response.to.have.status(200));"] } }]
        },
        {
          "name": "Delete ai-model #2",
          "request": { "method": "DELETE", "url": "{{baseUrl}}/api/ai-models/{{model2Id}}" },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.test('Status 200', () => pm.response.to.have.status(200));"] } }]
        }
