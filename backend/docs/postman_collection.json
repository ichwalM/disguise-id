    {
      "name": "11. RBAC Scenario (Operator)",
      "item": [
        {
          "name": "Login sebagai Operator (pakai user dari folder 4)",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/auth/login",
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"postman.operator@disguise.id\",\n  \"password\": \"OperatorPass123!\"\n}" }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const json = pm.response.json();",
                  "pm.test('roleId Operator = 2', () => pm.expect(json.user.roleId).to.eql(2));",
                  "pm.collectionVariables.set('operatorToken', json.token);"
                ]
              }
            }
          ]
        },
        {
          "name": "Operator POST forensic-cases (expect 201, diizinkan)",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{operatorToken}}", "type": "string" }] },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/forensic-cases",
            "body": { "mode": "raw", "raw": "{\n  \"case_number\": \"RBAC-OPERATOR-OK\"\n}" }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 201 (Operator diizinkan)', () => pm.response.to.have.status(201));",
                  "if (pm.response.code === 201) { pm.collectionVariables.set('caseId', pm.response.json().id); }"
                ]
              }
            }
          ]
        },
        {
          "name": "Operator POST datasets (expect 403, ditolak)",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{operatorToken}}", "type": "string" }] },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/datasets",
            "body": { "mode": "raw", "raw": "{\n  \"dataset_name\": \"RBAC Should Fail\"\n}" }
          },
          "event": [
            {
              "listen": "test",
              "script": { "type": "text/javascript", "exec": ["pm.test('Status 403 (Operator ditolak)', () => pm.response.to.have.status(403));"] }
            }
          ]
        },
        {
          "name": "Operator GET users (expect 403, super-admin only)",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{operatorToken}}", "type": "string" }] },
            "method": "GET",
            "url": "{{baseUrl}}/api/users"
          },
          "event": [
            {
              "listen": "test",
              "script": { "type": "text/javascript", "exec": ["pm.test('Status 403 (Operator ditolak)', () => pm.response.to.have.status(403));"] }
            }
          ]
        },
        {
          "name": "Cleanup: delete case RBAC-OPERATOR-OK (Super Admin)",
          "request": { "method": "DELETE", "url": "{{baseUrl}}/api/forensic-cases/{{caseId}}" },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.test('Status 200', () => pm.response.to.have.status(200));"] } }]
        },
        {
          "name": "Cleanup: delete user Operator test (Super Admin)",
          "request": { "method": "DELETE", "url": "{{baseUrl}}/api/users/{{operatorUserId}}" },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.test('Status 200', () => pm.response.to.have.status(200));"] } }]
        }
      ]
    }
