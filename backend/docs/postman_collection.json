          },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.test('Status 200', () => pm.response.to.have.status(200));"] } }]
        },
        {
          "name": "Delete training log",
          "request": { "method": "DELETE", "url": "{{baseUrl}}/api/ai-training-logs/{{trainingLogId}}" },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.test('Status 200', () => pm.response.to.have.status(200));"] } }]
        },
        {
          "name": "Cleanup: delete ai-model training target",
          "request": { "method": "DELETE", "url": "{{baseUrl}}/api/ai-models/{{modelId}}" },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.test('Status 200', () => pm.response.to.have.status(200));"] } }]
        }
      ]
    },
