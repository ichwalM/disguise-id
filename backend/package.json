{
  "name": "disguise-api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch --env-file=.env.local src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node --env-file=.env.local dist/server.js",
    "migrate": "node --env-file=.env.local scripts/migrate.mjs",
    "migrate:status": "node --env-file=.env.local scripts/migrate.mjs --status",
    "migrate:make": "node scripts/make-migration.mjs"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "jose": "^6.1.3",
    "mysql2": "^3.22.5"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20",
    "tsx": "^4.19.2",
    "typescript": "^5"
  }
}
