# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies (unanchored so it also covers backend/node_modules, etc.)
node_modules
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
coverage

# next.js
/.next/
/out/

# production / build output (root Next.js build + backend tsc output)
/build
dist/

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
package-lock.jso
